{
  "info": {
    "_postman_id": "fda9e1c4-1eef-4a1e-b9a1-ff89c6b8a001",
    "name": "ePassport — 20-minute Demo",
    "description": "Curated walkthrough of the demo's centrepieces: login, gate scan green/red/impersonation, permit hard-block, anonymous hazard report, dashboards, webhooks, API keys.\n\nVariables to set:\n- `base_url` (default http://127.0.0.1:8000)\n- `email`, `password` (default seeded demo credentials)\n\nThe `Login` request stores the bearer token into `{{token}}` automatically. Subsequent requests use it.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "email", "value": "khalid.maincon@epassport.local" },
    { "key": "password", "value": "password" },
    { "key": "token", "value": "" },
    { "key": "worker_id", "value": "" },
    { "key": "equipment_id", "value": "" },
    { "key": "permit_id", "value": "" },
    { "key": "anonymous_report_id", "value": "" }
  ],
  "item": [
    {
      "name": "1. Health probe",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/api/v1/health", "host": ["{{base_url}}"], "path": ["api","v1","health"] }
      }
    },
    {
      "name": "2. Login (token mode) — saves bearer to {{token}}",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json().data;",
              "pm.collectionVariables.set('token', data.access_token);",
              "console.log('Token saved.');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"mode\": \"token\",\n  \"device_name\": \"postman-demo\"\n}" },
        "url": { "raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api","v1","auth","login"] }
      }
    },
    {
      "name": "3. /me — authenticated identity + orgs",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{base_url}}/api/v1/me", "host": ["{{base_url}}"], "path": ["api","v1","me"] }
      }
    },
    {
      "name": "4. Workers — list (paginated)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{base_url}}/api/v1/workers?per_page=10&include=employerOrganization",
          "host": ["{{base_url}}"],
          "path": ["api","v1","workers"],
          "query": [
            { "key": "per_page", "value": "10" },
            { "key": "include", "value": "employerOrganization" }
          ]
        }
      }
    },
    {
      "name": "5. Workers — search 'Mohammed'",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{base_url}}/api/v1/workers?filter[search]=Mohammed",
          "host": ["{{base_url}}"],
          "path": ["api","v1","workers"],
          "query": [{ "key": "filter[search]", "value": "Mohammed" }]
        }
      }
    },
    {
      "name": "6. Worker e-Passport — full identity + certs + medical",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{base_url}}/api/v1/workers/{{worker_id}}/passport",
          "host": ["{{base_url}}"],
          "path": ["api","v1","workers","{{worker_id}}","passport"]
        }
      },
      "description": "Set {{worker_id}} from the list response above."
    },
    {
      "name": "7. Worker — helmet QR (image/png)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{base_url}}/api/v1/workers/{{worker_id}}/qr/helmet",
          "host": ["{{base_url}}"],
          "path": ["api","v1","workers","{{worker_id}}","qr","helmet"]
        }
      }
    },
    {
      "name": "8. Scan: GREEN happy path (replace `token` with a clean worker's helmet token)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"token\": \"<paste a clean worker's helmet_qr_token>\"\n}" },
        "url": { "raw": "{{base_url}}/api/v1/scans/verify", "host": ["{{base_url}}"], "path": ["api","v1","scans","verify"] }
      }
    },
    {
      "name": "9. Scan: RED — expired cert worker",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"token\": \"<paste a worker token with expired cert>\"\n}" },
        "url": { "raw": "{{base_url}}/api/v1/scans/verify", "host": ["{{base_url}}"], "path": ["api","v1","scans","verify"] }
      }
    },
    {
      "name": "10. Scan: IMPERSONATION_FLAG (helmet from worker A + coverall from worker B)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"helmet_token\": \"<helmet of worker A>\",\n  \"coverall_token\": \"<coverall of worker B>\"\n}" },
        "url": { "raw": "{{base_url}}/api/v1/scans/verify-pair", "host": ["{{base_url}}"], "path": ["api","v1","scans","verify-pair"] }
      }
    },
    {
      "name": "11. Permit: create draft (HOT_WORK)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"project_id\": \"<project uuid>\",\n  \"issuing_organization_id\": \"<main contractor org uuid>\",\n  \"permit_type_id\": \"<HOT_WORK permit type uuid>\",\n  \"scope_en\": \"Welding work on level 12 west columns\",\n  \"scope_ar\": \"أعمال لحام على الطابق 12 الأعمدة الغربية\"\n}" },
        "url": { "raw": "{{base_url}}/api/v1/permits", "host": ["{{base_url}}"], "path": ["api","v1","permits"] }
      }
    },
    {
      "name": "12. Permit: attach worker (causes hard-block)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"workers\": [\n    { \"id\": \"<worker uuid with expired cert>\", \"role_on_permit\": \"worker\" }\n  ]\n}" },
        "url": { "raw": "{{base_url}}/api/v1/permits/{{permit_id}}/workers", "host": ["{{base_url}}"], "path": ["api","v1","permits","{{permit_id}}","workers"] }
      }
    },
    {
      "name": "13. Permit: SUBMIT — expect 422 PERMIT_VALIDATION_FAILED",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{base_url}}/api/v1/permits/{{permit_id}}/submit", "host": ["{{base_url}}"], "path": ["api","v1","permits","{{permit_id}}","submit"] }
      },
      "description": "The 422 body contains worker_failures[] with the exact employee_id, full_name_en, and reasons[{code, expired_on, certification_type}] — this is the demo's most important error screen."
    },
    {
      "name": "14. Anonymous hazard report (PUBLIC, no auth, multipart)",
      "request": {
        "method": "POST",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "photo", "type": "file" },
            { "key": "category", "value": "fall", "type": "text" },
            { "key": "severity", "value": "high", "type": "text" },
            { "key": "description", "value": "Loose scaffold board on level 12 west", "type": "text" },
            { "key": "description_lang", "value": "en", "type": "text" }
          ]
        },
        "url": { "raw": "{{base_url}}/api/v1/hazard-reports/anonymous", "host": ["{{base_url}}"], "path": ["api","v1","hazard-reports","anonymous"] }
      },
      "description": "Photo EXIF stripped server-side. Response includes anonymous_report_id (UUID handle) — store it for the public status check."
    },
    {
      "name": "15. Public status check (no auth)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/api/v1/hazard-reports/anonymous/{{anonymous_report_id}}", "host": ["{{base_url}}"], "path": ["api","v1","hazard-reports","anonymous","{{anonymous_report_id}}"] }
      }
    },
    {
      "name": "16. Dashboard — main contractor",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{base_url}}/api/v1/dashboards/main-contractor/summary", "host": ["{{base_url}}"], "path": ["api","v1","dashboards","main-contractor","summary"] }
      }
    },
    {
      "name": "17. Webhook — subscribe to scan + permit + hazard events",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"owner_organization_id\": \"<main contractor org uuid>\",\n  \"label\": \"erp-integration\",\n  \"url\": \"https://your-receiver.example/webhooks/epassport\",\n  \"events\": [\"scan.red\", \"scan.impersonation_flag\", \"permit.approved\", \"hazard_report.submitted\"]\n}" },
        "url": { "raw": "{{base_url}}/api/v1/webhooks", "host": ["{{base_url}}"], "path": ["api","v1","webhooks"] }
      },
      "description": "Response includes the HMAC-SHA256 secret ONCE. Each delivery to your URL carries headers: X-ePassport-Event, X-ePassport-Event-Id (dedupe), X-ePassport-Signature (sha256=<hex>), X-ePassport-Delivery-Attempt."
    },
    {
      "name": "18. API key — issue scoped key for ERP",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"sap-erp-integration\",\n  \"abilities\": [\"workers.read\", \"equipment.read\", \"permits.read\", \"scans.read\"],\n  \"expires_at\": \"2027-12-31T23:59:59Z\"\n}" },
        "url": { "raw": "{{base_url}}/api/v1/auth/api-keys", "host": ["{{base_url}}"], "path": ["api","v1","auth","api-keys"] }
      }
    }
  ]
}
