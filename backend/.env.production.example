APP_NAME=ePassport
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://api.epassport.example

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=epassport
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
# Same registrable domain so api.* and app.* share the Sanctum cookie
SESSION_DOMAIN=.epassport.example
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=epassport_prod

REDIS_CLIENT=predis
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# SPA origins allowed to authenticate via Sanctum cookie session
SANCTUM_STATEFUL_DOMAINS=app.epassport.example

# Mail
MAIL_MAILER=postmark
MAIL_FROM_ADDRESS="no-reply@epassport.example"
MAIL_FROM_NAME="${APP_NAME}"
POSTMARK_TOKEN=

# AWS S3 — Saudi region for PDPL data residency
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=me-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Sentry
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

# Scribe internal token used by 'Try it out' on /docs
SCRIBE_AUTH_KEY=
