# MVP production envs — Render (backend) + Supabase (Postgres) + Cloudflare R2 (photos).
# Copy each VAR=value into Render's "Environment" tab (or fly secrets / railway).
# Anything not listed here keeps its default from config/*.php.

APP_NAME=ePassport
APP_ENV=production
APP_KEY=                              # generate locally: `php artisan key:generate --show`
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://YOUR-BACKEND.onrender.com
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single                      # Render captures stdout — no rotation needed
LOG_LEVEL=warning

# Database — Supabase free Postgres (project Settings → Database → Connection string)
DB_CONNECTION=pgsql
DB_HOST=                              # aws-0-xxx.pooler.supabase.com
DB_PORT=6543                          # use pooler port; 5432 also works
DB_DATABASE=postgres
DB_USERNAME=                          # postgres.<project-ref>
DB_PASSWORD=

# Sessions / cache / queue — no Redis for MVP
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=                       # leave blank when api + web are different hosts
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
CACHE_STORE=database
CACHE_PREFIX=epassport_prod
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log

# Web frontend on Vercel — needed for cookie auth from the SPA
SANCTUM_STATEFUL_DOMAINS=YOUR-WEB.vercel.app

# Mail (MVP: log channel; swap to a real provider later)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@epassport.local"
MAIL_FROM_NAME="${APP_NAME}"

# Photo storage — Cloudflare R2 (S3-compatible)
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=                    # R2 API token → Access Key ID
AWS_SECRET_ACCESS_KEY=                # R2 API token → Secret
AWS_DEFAULT_REGION=auto
AWS_BUCKET=epassport-hazard-photos
AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

# Optional — leave blank to disable
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SCRIBE_AUTH_KEY=
